{
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch",
      "mcp__codex__codex",
      "mcp__codex__review",
      "mcp__codex__websearch",
      "mcp__codex__help",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(tr *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(xargs *)",
      "Bash(tee *)",
      "Bash(diff *)",
      "Bash(diffstat *)",
      "Bash(comm *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(pwd *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln *)",
      "Bash(tar *)",
      "Bash(unzip *)",
      "Bash(gzip *)",
      "Bash(gunzip *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(envsubst *)",
      "Bash(date *)",
      "Bash(sleep *)",
      "Bash(true *)",
      "Bash(false *)",
      "Bash(test *)",
      "Bash([ *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(code *)",
      "Bash(open *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(go *)",
      "Bash(make *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(terraform *)",
      "Bash(aws *)",
      "Bash(mongosh *)",
      "Bash(redis-cli *)",
      "Bash(ruff *)",
      "Bash(golangci-lint *)",
      "Bash(protoc *)",
      "Bash(buf *)",
      "Bash(FILE=*)",
      "Bash(LIVERPOOL_ENV=*)",
      "Bash(GOFLAGS=*)",
      "Bash(CGO_ENABLED=*)",
      "Bash(PATH=*)",
      "Bash(cd *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /*)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Codeが許可を求めています\" with title \"Claude Code\" subtitle \"確認待ち\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"タスクが完了しました\" with title \"Claude Code\" subtitle \"処理終了\" sound name \"Hero\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx ccusage statusline"
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "mcp-apps@mcp-apps": true,
    "common-dev@awa-plugins": true,
    "github@claude-plugins-official": true,
    "infra-dev@awa-plugins": true,
    "admintool-dev@awa-plugins": true,
    "server-dev@awa-plugins": true,
    "write-postmortem@awa-plugins": true,
    "document-dev@awa-plugins": true,
    "discord@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "outputStyle": "Explanatory",
  "alwaysThinkingEnabled": true,
  "tui": "fullscreen",
  "voiceEnabled": true,
  "mcpServers": {
    "admintool-dev": {
      "type": "http",
      "url": "http://dev-admintool-mcp.in.awa.io/mcp"
    },
    "admintool-prd": {
      "type": "http",
      "url": "http://prd-admintool-mcp.in.awa.io/mcp"
    },
    "awa-doc": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "ghcr.io/awa/doc-mcp-server:latest"
      ]
    },
    "awa-slack": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "AWS_SSM_SLACK_TOKEN_NAME",
        "-e",
        "AWS_REGION",
        "-v",
        "${HOME}/.aws:/root/.aws:ro",
        "ghcr.io/awa/mcp-slack:latest"
      ],
      "env": {
        "AWS_SSM_SLACK_TOKEN_NAME": "/mcp-slack/bot-token",
        "AWS_REGION": "ap-northeast-1"
      }
    },
    "aws-mcp": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=ap-northeast-1"
      ]
    },
    "awslabs.aws-api-mcp-server": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "--interactive",
        "--env",
        "AWS_API_MCP_PROFILE_NAME=default",
        "--volume",
        "/Users/s11639/.aws:/app/.aws",
        "public.ecr.aws/awslabs-mcp/awslabs/aws-api-mcp-server:latest"
      ]
    },
    "awslabs.aws-documentation-mcp-server": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "--interactive",
        "--env",
        "FASTMCP_LOG_LEVEL=ERROR",
        "--env",
        "AWS_DOCUMENTATION_PARTITION=aws",
        "mcp/aws-documentation:latest"
      ]
    },
    "cloudflare-docs": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://docs.mcp.cloudflare.com/mcp"
      ]
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    },
    "stripe": {
      "command": "npx",
      "args": [
        "-y",
        "@stripe/mcp"
      ],
      "env": {
        "STRIPE_SECRET_KEY": "to be added"
      }
    },
    "terraform": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "hashicorp/terraform-mcp-server:latest"
      ]
    },
    "mise": {
      "command": "mise",
      "args": [
        "mcp"
      ],
      "env": {
        "MISE_EXPERIMENTAL": "1"
      }
    },
    "codex": {
      "command": "codex",
      "args": [
        "mcp-server"
      ]
    },
    "drawio": {
      "command": "npx",
      "args": [
        "-y",
        "@drawio/mcp"
      ]
    },
    "canva": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://mcp.canva.com/mcp"
      ]
    },
    "dxe-atlassian": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://mcp.atlassian.com/v1/sse"
      ],
      "env": {
        "CONFLUENCE_USERNAME": "",
        "CONFLUENCE_API_TOKEN": ""
      }
    },
    "docbase-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://mcp.docbase.io/mcp"
      ]
    },
    "note": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "NOTE_COOKIES",
        "-e",
        "MAGAZINES_DIR=/magazines",
        "-v",
        "/Users/s11639/dev/me/mcp-note/magazines:/magazines",
        "mcp-note"
      ],
      "env": {
        "NOTE_COOKIES": "to_be_added..."
      }
    },
    "figma": {
      "command": "node",
      "args": [
        "/Users/s11639/go/src/github.com/awa/figjam_mcp/dist/index.js"
      ],
      "env": {
        "BRIDGE_PORT": "3000"
      }
    },
    "ga4-analytics": {
      "command": "ga4-mcp-server",
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "/Users/s11639/.config/gcloud/ga4-reader-key.json",
        "GA4_PROPERTY_ID": "531043911"
      }
    },
    "astro-docs": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.docs.astro.build/mcp"
      ]
    },
    "hono-docs": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://hono-docs-mcp.yusukebe.workers.dev/mcp"
      ]
    },
    "simply-rag": {
      "type": "http",
      "url": "https://rag.simply.dev/search",
      "headers": {
        "x-api-key": "to be added"
      }
    }
  }
}
